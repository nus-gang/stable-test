# syntax=docker/dockerfile:1
FROM golang:1.23.2-bookworm

ARG DEBIAN_FRONTEND=noninteractive
ARG IGNITE_VERSION=29.10.1
ARG IGNITE_SCAFFOLD_GO_VERSION=1.25.12
ARG IGNITE_BUF_VERSION=1.56.0

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        git \
        jq \
        make \
        gcc \
        g++ \
        libc6-dev \
        pkg-config \
        protobuf-compiler \
        rsync \
        tar \
        unzip \
        vim \
    && rm -rf /var/lib/apt/lists/*

RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    case "$arch" in \
      amd64) ignite_arch="amd64" ;; \
      arm64) ignite_arch="arm64" ;; \
      *) echo "Unsupported architecture for Ignite CLI: $arch" >&2; exit 1 ;; \
    esac; \
    curl -fsSL "https://github.com/ignite/cli/releases/download/v${IGNITE_VERSION}/ignite_${IGNITE_VERSION}_linux_${ignite_arch}.tar.gz" -o /tmp/ignite.tar.gz; \
    tar -xzf /tmp/ignite.tar.gz -C /tmp; \
    install -m 0755 /tmp/ignite /usr/local/bin/ignite; \
    rm -f /tmp/ignite.tar.gz /tmp/ignite; \
    ignite version

# Ignite v29 scaffolding and its latest transitive tool dependencies can require
# Go 1.25.x during the temporary scaffold `go mod tidy` step. Keep the primary
# project baseline at Go 1.23.2, but install a scaffold-only Go 1.25.12 helper.
RUN set -eux; \
    go install golang.org/dl/go${IGNITE_SCAFFOLD_GO_VERSION}@latest; \
    go${IGNITE_SCAFFOLD_GO_VERSION} download; \
    go${IGNITE_SCAFFOLD_GO_VERSION} version

# Ignite invokes buf through `go tool github.com/bufbuild/buf/cmd/buf`.
# With Go tool directives and no explicit require, Go resolves the latest buf,
# which can require an unreleased Go toolchain. Wrap only that go-tool call and
# pin buf to the version used by Ignite v29.10.1 itself.
RUN set -eux; \
    mv /usr/local/go/bin/go /usr/local/go/bin/go-real; \
    printf '%s\n' \
      '#!/usr/bin/env bash' \
      'set -euo pipefail' \
      'if [ "${1:-}" = "tool" ] && [ "${2:-}" = "github.com/bufbuild/buf/cmd/buf" ]; then' \
      '  shift 2' \
      '  exec /go/bin/go${IGNITE_SCAFFOLD_GO_VERSION:-1.25.12} run github.com/bufbuild/buf/cmd/buf@v${IGNITE_BUF_VERSION:-1.56.0} "$@"' \
      'fi' \
      'exec /usr/local/go/bin/go-real "$@"' \
      > /usr/local/go/bin/go; \
    chmod 0755 /usr/local/go/bin/go; \
    ln -sf /usr/local/go/bin/go /usr/local/bin/go; \
    which go; \
    go version; \
    go1.25.12 version

ENV CGO_ENABLED=1
ENV GOPATH=/go
ENV PATH="/usr/local/bin:/go/bin:${PATH}"
ENV CHAIN_ID=stablecoin-private-1
ENV CHAIN_HOME=/workspace/.chain-data
ENV CHAIN_BINARY=stablecoind
ENV IGNITE_VERSION=${IGNITE_VERSION}
ENV IGNITE_SCAFFOLD_GO_VERSION=${IGNITE_SCAFFOLD_GO_VERSION}
ENV IGNITE_BUF_VERSION=${IGNITE_BUF_VERSION}

WORKDIR /workspace

CMD ["bash"]
