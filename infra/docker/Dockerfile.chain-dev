# syntax=docker/dockerfile:1
FROM golang:1.23.2-bookworm

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        git \
        jq \
        make \
        gcc \
        g++ \
        libc6-dev \
        pkg-config \
        protobuf-compiler \
        unzip \
        vim \
    && rm -rf /var/lib/apt/lists/*

ENV CGO_ENABLED=1
ENV GOPATH=/go
ENV PATH="/go/bin:${PATH}"
ENV CHAIN_ID=stablecoin-private-1
ENV CHAIN_HOME=/workspace/.chain-data
ENV CHAIN_BINARY=stablecoind

WORKDIR /workspace

CMD ["bash"]
